rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // ALLOWLIST: somente estes 4 e-mails podem usar o app.
    function isAllowedUser() {
      return isSignedIn()
        && request.auth.token.email.lower() in [
          'laetiessentia@gmail.com',
          'gabriela2004t@gmail.com',
          'iamleticiamartins67@gmail.com',
          'ltomio@gmail.com'
        ];
    }

    // Verifica se um documento pertence ao workspace único.
    function belongsToWorkspace(data) {
      return isAllowedUser()
        && 'workspaceId' in data
        && data.workspaceId == 'th1su6PkVx9Gjwkdocqr';
    }

    match /users/{uid} {
      allow read: if isAllowedUser();
      allow create, update: if isAllowedUser() && request.auth.uid == uid;
      allow delete: if false;
    }

    match /workspaces/{workspaceId} {
      allow get: if isAllowedUser() && workspaceId == 'th1su6PkVx9Gjwkdocqr';
      allow list: if isAllowedUser();
      allow create, update, delete: if false;
    }

    // Todas as coleções de dados são escopadas ao workspace único.
    match /{collectionName}/{docId} {
      allow read, update, delete: if collectionName in [
          'settings', 'lightTools', 'heavyAssets', 'supplyCategories',
          'supplies', 'supplyEntries', 'marketplaces',
          'semiFinishedComponents', 'products'
        ] && belongsToWorkspace(resource.data);
      allow create: if collectionName in [
          'settings', 'lightTools', 'heavyAssets', 'supplyCategories',
          'supplies', 'supplyEntries', 'marketplaces',
          'semiFinishedComponents', 'products'
        ] && belongsToWorkspace(request.resource.data);
    }
  }
}
