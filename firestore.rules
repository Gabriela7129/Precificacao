rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // ALLOWLIST: somente estes 4 e-mails podem usar o app.
    // Qualquer outra conta Google é bloqueada em TUDO (leitura e escrita).
    function isAllowedUser() {
      return isSignedIn()
        && request.auth.token.email.lower() in [
          'laetiessentia@gmail.com',
          'gabriela2004t@gmail.com',
          'lettprincesa@gmail.com',
          'ltomio@hotmail.com'
        ];
    }

    // Um usuário é membro de um workspace se seu uid está no array memberIds
    // do documento do workspace (espelho da subcoleção members, usado para
    // queries e regras).
    function isMember(workspaceId) {
      return isAllowedUser()
        && exists(/databases/$(database)/documents/workspaces/$(workspaceId))
        && request.auth.uid in get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.memberIds;
    }

    // Verifica membership a partir do campo workspaceId de um documento.
    function isWorkspaceDoc(data) {
      return isAllowedUser() && 'workspaceId' in data && isMember(data.workspaceId);
    }

    match /users/{uid} {
      allow read: if isAllowedUser();
      allow create, update: if isAllowedUser() && request.auth.uid == uid;
      allow delete: if false;
    }

    match /workspaces/{workspaceId} {
      // GET (documento único): pode usar get()/exists() normalmente.
      allow get: if isMember(workspaceId);
      // LIST (consultas): regras NÃO são filtros — a consulta precisa ser
      // provavelmente segura apenas com os dados do próprio documento.
      // Por isso usamos resource.data.memberIds aqui (a query do app já
      // filtra com array-contains no mesmo campo).
      allow list: if isAllowedUser() && request.auth.uid in resource.data.memberIds;
      allow create: if isAllowedUser()
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.memberIds;
      // UPDATE: membros podem tudo; um convidado pode APENAS se adicionar a
      // memberIds (auto-join), e somente se existir convite pendente para o
      // e-mail da conta Google dele (doc `members/invite_<email>`).
      allow update: if isMember(workspaceId)
        || (isAllowedUser()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds'])
          && request.auth.uid in request.resource.data.memberIds
          && !(request.auth.uid in resource.data.memberIds)
          && exists(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$('invite_' + request.auth.token.email.lower())));
      allow delete: if isMember(workspaceId);

      match /members/{memberId} {
        // GET: membros do workspace, ou o próprio usuário lendo seu registro.
        allow get: if isMember(workspaceId)
          || (isAllowedUser() && resource.data.userId == request.auth.uid);
        // LIST: membros do workspace listam tudo; usuário da allowlist pode
        // descobrir convites pendentes endereçados ao próprio e-mail
        // (usado pela query collectionGroup "tenho convites?").
        allow list: if isMember(workspaceId)
          || (isAllowedUser() && resource.data.email == request.auth.token.email.lower());
        allow create: if isAllowedUser()
          && (isMember(workspaceId) || request.resource.data.userId == request.auth.uid);
        allow update: if isMember(workspaceId);
        // DELETE: membros do workspace; ou o convidado removendo o próprio
        // convite (usado ao aceitar o convite).
        allow delete: if isMember(workspaceId)
          || (isAllowedUser() && resource.data.email == request.auth.token.email.lower());
      }
    }

    // Todas as coleções de dados são escopadas por workspaceId.
    match /{collectionName}/{docId} {
      allow read, update, delete: if collectionName in [
          'settings', 'lightTools', 'heavyAssets', 'supplyCategories',
          'supplies', 'supplyEntries', 'marketplaces',
          'semiFinishedComponents', 'products'
        ] && isWorkspaceDoc(resource.data);
      allow create: if collectionName in [
          'settings', 'lightTools', 'heavyAssets', 'supplyCategories',
          'supplies', 'supplyEntries', 'marketplaces',
          'semiFinishedComponents', 'products'
        ] && isWorkspaceDoc(request.resource.data);
    }
  }
}
